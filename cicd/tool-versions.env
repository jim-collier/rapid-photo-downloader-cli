# Pinned toolchain + tool versions - the single source of truth for both the
# local pipeline (cicd/) and hosted CI (.github/workflows/). Bumps arrive as
# dependabot PRs against dev (see .github/dependabot.yml). Keep values as bare
# tags; the install helpers add the leading 'go install ...@' or 'v' as needed.
#
# Sourced by bash (KEY=value, no spaces). CI reads it the same way.

# Go toolchain. Matches the go directive that lands in go.mod later.
GO_VERSION=1.26.2

# Security suites the test harness actually runs (test.bash probes these).
GOVULNCHECK_VERSION=v1.6.0
GOSEC_VERSION=v2.27.1

# Linters the backlog wants pinned. Not wired into test.bash yet (it uses
# `go vet`); pinned here so lint-report.bash / CI can adopt them at one version.
GOLANGCI_LINT_VERSION=v2.12.2
STATICCHECK_VERSION=2026.1

# Release packaging (release workflow + `goreleaser check`).
GORELEASER_VERSION=v2.17.0

# Linux .deb/.rpm builder (go install; local pipeline + goreleaser both use it).
NFPM_VERSION=v2.47.0

# Windows installer .exe is built with NSIS (makensis) - a system package, not a
# go tool, so it is not pinned here. Install with the OS pkg manager: `apt install
# nsis` / `dnf install mingw32-nsis`. Missing -> the Windows installer step skips.
